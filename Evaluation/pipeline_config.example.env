# Copy this file to Evaluation/pipeline_config.env and edit values.

# Root folder where per-run folders are created.
RUNS_ROOT=Evaluation/test_pipeline_1
# Optional fixed run name. If empty, timestamp is used.
# RUN_NAME=run_20260604_150000

# Stage control. Default workflow for this setup is preprocessing + post-pretrain.
STAGES=prepare_clips,post_pretrain

# Runtime binaries
PYTHON_BIN=/root/Desktop/Project/.venv/bin/python
TORCHRUN_BIN=torchrun
NPROC_PER_NODE=1
MASTER_PORT=29511

# ----------------------------
# Stage 0: unlabeled video preprocessing
# ----------------------------
PREP_INPUT_CSV=/root/Desktop/预训练数据集_0603_实际路径_found.csv
PREP_OUTPUT_DIR=/root/Desktop/VideoMAEv2/Data/dataset_post_pretrain
PREP_METADATA_DIR=/root/Desktop/VideoMAEv2/Data/dataset_post_pretrain_metadata
PREP_MANIFEST_PATH=/root/Desktop/VideoMAEv2/Data/dataset_post_pretrain_manifest.csv
PREP_MODEL_ID=iic/cv_tinynas_head-detection_damoyolo
PREP_OUTPUT_SIZE=224
PREP_CROP_SCALE=2.4
PREP_SCORE_THRESHOLD=0.35
PREP_SMOOTH_ALPHA=0.80
PREP_MAX_VIDEOS=0
PREP_MAX_FRAMES=0
PREP_DEVICE=cuda
PREP_PATH_COLUMN=实际路径
PREP_ID_COLUMN=编号
PREP_SKIP_EXISTING=1
PREP_DRAW_BOXES=0
# PREP_EXTRA_ARGS=""

# ----------------------------
# Stage 1: post-pretraining
# ----------------------------
# If empty, stage 1 uses the stage-0 processed videos in RUN_DIR/prepared_clips/videos.
UNLABELED_CLIPS_DIR=/root/Desktop/VideoMAEv2/Data/dataset_post_pretrain
POST_INIT_CKPT=/root/Desktop/vit_h_model.safetensors
POST_MODEL=pretrain_videomae_huge_patch16_224
POST_MASK_TYPE=tube
POST_MASK_RATIO=0.9
POST_DECODER_MASK_TYPE=run_cell
POST_DECODER_MASK_RATIO=0.5
POST_DECODER_DEPTH=4
POST_EPOCHS=50
POST_BATCH_SIZE=4
POST_NUM_FRAMES=16
POST_SAMPLING_RATE=4
POST_NUM_SAMPLE=2
POST_NUM_WORKERS=4
POST_INPUT_SIZE=224
POST_LR=1e-4
POST_OPT=adamw
POST_OPT_BETAS_A=0.9
POST_OPT_BETAS_B=0.95
POST_WARMUP_EPOCHS=5
POST_SAVE_CKPT_FREQ=5
POST_DEVICE=cuda
# POST_EXTRA_ARGS="--with_checkpoint"

# ----------------------------
# Stage 2: finetuning
# ----------------------------
# Folder must contain train.csv, val.csv, test.csv
FINETUNE_DATA_PATH=Data/dataset_finetuning
FINETUNE_DATA_ROOT=
# Optional override. If empty, uses stage1 exported checkpoint.
# FINETUNE_INIT_CKPT=/absolute/path/to/post_pretrained.pth

FIN_MODEL=vit_base_patch16_224
FIN_DATA_SET=Kinetics-400
FIN_NB_CLASSES=2
FIN_EPOCHS=35
FIN_BATCH_SIZE=8
FIN_INPUT_SIZE=224
FIN_SHORT_SIDE_SIZE=224
FIN_SAVE_CKPT_FREQ=5
FIN_NUM_FRAMES=16
FIN_SAMPLING_RATE=4
FIN_NUM_SAMPLE=2
FIN_NUM_WORKERS=4
FIN_OPT=adamw
FIN_LR=1e-3
FIN_DROP_PATH=0.3
FIN_CLIP_GRAD=5.0
FIN_LAYER_DECAY=0.9
FIN_WEIGHT_DECAY=0.1
FIN_WARMUP_EPOCHS=5
FIN_TEST_NUM_SEGMENT=5
FIN_TEST_NUM_CROP=3
FIN_DEVICE=cuda
# FIN_EXTRA_ARGS="--disable_eval_during_finetuning"

# ----------------------------
# Stage 3: evaluation
# ----------------------------
# Optional override. If empty, uses stage2 exported checkpoint.
# EVAL_CKPT=/absolute/path/to/eval_checkpoint.pth

EVAL_MODEL=vit_base_patch16_224
EVAL_DATA_SET=Kinetics-400
EVAL_NB_CLASSES=2
EVAL_BATCH_SIZE=8
EVAL_INPUT_SIZE=224
EVAL_SHORT_SIDE_SIZE=224
EVAL_NUM_FRAMES=16
EVAL_SAMPLING_RATE=4
EVAL_NUM_WORKERS=4
EVAL_TEST_NUM_SEGMENT=5
EVAL_TEST_NUM_CROP=3
EVAL_DEVICE=cuda
# EVAL_EXTRA_ARGS=""
